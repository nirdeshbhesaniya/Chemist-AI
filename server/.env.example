PORT=5000
MONGO_URI=mongodb://localhost:27017/chemist-ai
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# OpenRouter (Free LLM - get key at https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_MODEL=deepseek/deepseek-r1:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# PubChem (Free - no key needed)
PUBCHEM_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug

# PatentsView - Free USPTO Patent API (no key needed)
PATENTSVIEW_BASE_URL=https://api.patentsview.org/patents/query

# SerpAPI (optional, for Google Patents - free tier 100/month)
# SERPAPI_KEY=your_serpapi_key_here

CLIENT_URL=http://localhost:5173
